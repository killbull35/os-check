# Configuration pour os_risk_diag.sh
# Copier ce fichier en .env et adapter les valeurs

# Hôte OpenSearch (obligatoire)
OS_HOST=localhost:9200

# Authentification (obligatoire)
# Format: -u user:password
AUTH=-u admin:password

# Options curl supplémentaires (optionnel)
# Exemple pour TLS auto-signé : CURL_OPTS="-k"
CURL_OPTS=""

# Durée de validité du cache en secondes (optionnel, défaut: 300)
CACHE_TTL=300
